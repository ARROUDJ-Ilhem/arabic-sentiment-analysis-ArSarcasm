    {
      "cell_type": "markdown",
      "metadata": {
        "id": "vvS-lY8xItS5"
      },
      "source": [
        "## 1. Imports & Seeds"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 8,
      "metadata": {
        "id": "LARGXlnkItS5",
        "outputId": "d9bf97c7-3510-4560-bd2e-e1ab7fcd4c16",
        "colab": {
          "base_uri": "https://localhost:8080/"
        }
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "PyTorch: 2.10.0+cu128\n",
            "GPU: Tesla T4\n"
          ]
        }
      ],
      "source": [
        "import os, random, time, json\n",
        "import numpy as np\n",
        "import pandas as pd\n",
        "import torch\n",
        "from transformers import (\n",
        "    AutoTokenizer, AutoModelForSequenceClassification,\n",
        "    TrainingArguments, Trainer, EarlyStoppingCallback, set_seed\n",
        ")\n",
        "import evaluate\n",
        "from sklearn.metrics import f1_score, accuracy_score\n",
        "import matplotlib.pyplot as plt\n",
        "import warnings\n",
        "warnings.filterwarnings('ignore')\n",
        "\n",
        "# ── Import our local modules ──────────────────────────────────────────────────\n",
        "from src.preprocess import clean_arabic_tweet\n",
        "from src.dataset import ArabicTweetDataset, LABEL2ID, ID2LABEL, NUM_LABELS\n",
        "from src.evaluate import (\n",
        "    compute_metrics_from_arrays, print_classification_report,\n",
        "    plot_confusion_matrix, show_error_examples\n",
        ")\n",
        "\n",
        "print(f\"PyTorch: {torch.__version__}\")\n",
        "print(f\"GPU: {torch.cuda.get_device_name(0) if torch.cuda.is_available() else 'CPU'}\")"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 9,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "ZjcJ7RD5ItS5",
        "outputId": "fbe32fe8-199c-47ef-d9dd-591b3d9f4142"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Seeds set. SEED=42\n",
            "Remaining nondeterminism: CUDA atomicAdd in transformer attention backward pass.\n"
          ]
        }
      ],
      "source": [
        "SEED = 42\n",
        "\n",
        "def set_all_seeds(seed: int):\n",
        "    random.seed(seed)\n",
        "    np.random.seed(seed)\n",
        "    torch.manual_seed(seed)\n",
        "    torch.cuda.manual_seed_all(seed)\n",
        "    set_seed(seed)\n",
        "    os.environ['PYTHONHASHSEED'] = str(seed)\n",
        "    torch.backends.cudnn.deterministic = True\n",
        "    torch.backends.cudnn.benchmark = False\n",
        "\n",
        "set_all_seeds(SEED)\n",
        "print(f\"Seeds set. SEED={SEED}\")\n",
        "print(\"Remaining nondeterminism: CUDA atomicAdd in transformer attention backward pass.\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "-fNJbE5eItS5"
      },
      "source": [
        "## 2. Load Preprocessed Data"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 10,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "ktwew57VItS6",
        "outputId": "a9bae213-38e7-458b-e9eb-0599435c0e07"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Train: 7357 | Val: 1576 | Test: 1577\n",
            "\n",
            "Label distribution (train):\n",
            "label\n",
            "negative    3725\n",
            "positive    2464\n",
            "neutral     1168\n"
          ]
        }
      ],
      "source": [
        "# Load CSVs produced by scripts/prepare_data.py\n",
        "train_df = pd.read_csv('data/train.csv')\n",
        "val_df   = pd.read_csv('data/val.csv')\n",
        "test_df  = pd.read_csv('data/test.csv')\n",
        "\n",
        "print(f\"Train: {len(train_df)} | Val: {len(val_df)} | Test: {len(test_df)}\")\n",
        "print(f\"\\nLabel distribution (train):\")\n",
        "print(train_df['label'].value_counts().to_string())"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "zcnQBgP4ItS6"
      },
      "source": [
        "## 3. Tokeniser & Datasets"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 11,
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "id": "Ib93jPyBItS6",
        "outputId": "3750dcb7-744b-4a5e-ee31-67867e916d13"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Datasets built. Vocab size: 30000\n"
          ]
        }
      ],
      "source": [
        "# CAMeLBERT-Mix: BERT pre-trained on MSA + dialectal Arabic\n",
        "# Chosen over AraBERT (MSA only) and BiLSTM (no pre-trained Arabic repr.)\n",
        "MODEL_NAME = 'CAMeL-Lab/bert-base-arabic-camelbert-mix-sentiment'\n",
        "MAX_LEN    = 128\n",
        "\n",
        "tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)\n",
        "\n",
        "train_dataset = ArabicTweetDataset(train_df, tokenizer, MAX_LEN)\n",
        "val_dataset   = ArabicTweetDataset(val_df,   tokenizer, MAX_LEN)\n",
        "test_dataset  = ArabicTweetDataset(test_df,  tokenizer, MAX_LEN)\n",
        "\n",
        "print(f\"Datasets built. Vocab size: {tokenizer.vocab_size}\")"
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "Z6ObR40jItS6"
      },
      "source": [
        "## 4. Model & Training"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 17,
      "metadata": {
        "colab": {

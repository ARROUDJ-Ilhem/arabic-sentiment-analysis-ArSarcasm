      "source": [
        "## 6. Latency Measurement"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": 28,
      "metadata": {
        "id": "2XRv205XItS6",
        "colab": {
          "base_uri": "https://localhost:8080/"
        },
        "outputId": "4b0d664e-52fc-42ab-f225-102fd2f04b7f"
      },
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "Single-sample latency — mean: 13.51 ms | p95: 20.10 ms\n"
          ]
        }
      ],
      "source": [
        "device = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n",
        "model.eval().to(device)\n",
        "\n",
        "sample_enc = tokenizer(\n",
        "    test_df['text_clean'].iloc[0],\n",
        "    return_tensors='pt', truncation=True,\n",
        "    padding='max_length', max_length=MAX_LEN\n",
        ").to(device)\n",
        "\n",
        "N_WARMUP, N_RUNS = 20, 200\n",
        "\n",
        "with torch.no_grad():\n",
        "    for _ in range(N_WARMUP):\n",
        "        _ = model(**sample_enc)\n",
        "\n",
        "latencies = []\n",
        "with torch.no_grad():\n",
        "    for _ in range(N_RUNS):\n",
        "        if torch.cuda.is_available(): torch.cuda.synchronize()\n",
        "        t0 = time.perf_counter()\n",
        "        _ = model(**sample_enc)\n",
        "        if torch.cuda.is_available(): torch.cuda.synchronize()\n",
        "        latencies.append((time.perf_counter() - t0) * 1000)\n",
        "\n",
        "lat = np.array(latencies)\n",
        "print(f\"Single-sample latency — mean: {lat.mean():.2f} ms | p95: {np.percentile(lat,95):.2f} ms\")"
      ]
    },
